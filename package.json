{
  "name": "stage5.tools",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "audit:locales": "node scripts/audit-shared-locales.mjs",
    "build": "npm run audit:locales && next build",
    "start": "next start",
    "lint": "next lint",
    "pages:prepare": "next-on-pages --experimental-minify",
    "pages": "npm run build && npm run pages:prepare",
    "monitor:dev": "wrangler dev -c monitor/wrangler.toml",
    "monitor:deploy": "wrangler deploy -c monitor/wrangler.toml",
    "monitor:test": "node --test monitor/test/monitor.test.mjs",
    "monitor:demo:pass": "node monitor/scripts/demo-run.mjs pass",
    "monitor:demo:force": "node monitor/scripts/demo-run.mjs force"
  },
  "dependencies": {
    "lucide-react": "^0.513.0",
    "next": "15.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.12",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.18.0"
  }
}
